# Copia questo file in `.env.local` e incolla i valori dal tuo progetto Firebase
# (Console Firebase -> Impostazioni progetto -> Le tue app -> Configurazione SDK)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Integrazione Google Health (facoltativa) — OAuth Client ID da Google Cloud, vedi README
VITE_GOOGLE_HEALTH_CLIENT_ID=
